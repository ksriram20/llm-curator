# Copy to .env and fill in. .env is gitignored.

# --- Postgres (the curator's OWN database) ---
POSTGRES_PASSWORD=change-me-strong

# --- Model discovery / eval ---
OPENROUTER_API_KEY=
# Host Ollama as seen from inside the container (default works on Docker Desktop /
# Linux with host-gateway). Point elsewhere if Ollama runs on another machine.
OLLAMA_URL=http://host.docker.internal:11434

# --- LiteLLM config (read-only, OPTIONAL) ---
# Absolute host path to your litellm_config.yaml. Leave unset to run standalone
# (proposals/sync that need it will simply no-op).
LITELLM_CONFIG_PATH=/path/to/your/litellm_config.yaml

# --- Telegram alerts (OPTIONAL) ---
# Both must be set for alerts to send; otherwise notify() is a silent no-op.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
