CRON_TZ=Asia/Kolkata
PYTHONPATH=/app
PYTHONUNBUFFERED=1

# min  hour  dom  mon  dow  user  command
# /run_job.sh sources /etc/environment so cron jobs see CSR_DSN, API keys, etc.
37  2  * * *  root  /run_job.sh python -m llm_curator.eval_runner >> /proc/1/fd/1 2>&1
17  3  * * *  root  /run_job.sh python -m llm_curator.openrouter_discovery >> /proc/1/fd/1 2>&1
43  3  * * *  root  /run_job.sh python -m llm_curator.ollama_cloud_discovery >> /proc/1/fd/1 2>&1
23  9  * * 0  root  /run_job.sh python -m llm_curator.proposal_generator >> /proc/1/fd/1 2>&1
